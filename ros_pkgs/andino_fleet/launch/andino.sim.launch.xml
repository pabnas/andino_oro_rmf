<?xml version="1.0"?>
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="id" default="1" />
  <arg name="rviz" default="True" />

  <include file="$(find-pkg-share andino_fleet)/launch/spawn_multiple_robot.launch.py">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="id" value="$(var id)"/>
    <arg name="rviz" value="$(var rviz)"/>
  </include>

  <node pkg="battery_fake" exec="battery_fake" output="screen" />

  </launch>